# GitHub Kanban Viewer - Backend environment variables
# Copy this file to .env and fill in your values

# GitHub personal access token
# Required scopes: read:project (for Projects v2), repo (for private repos)
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# GitHub Projects v2 URL
# Supported formats:
#   https://github.com/orgs/YOUR_ORG/projects/1
#   https://github.com/users/YOUR_USER/projects/1
#   https://github.com/YOUR_USER/projects/1
GITHUB_PROJECT_URL=https://github.com/orgs/YOUR_ORG/projects/1

# How often to re-fetch from GitHub API (milliseconds)
# Default: 300000 (5 minutes)
# POLL_INTERVAL_MS=300000

# Server port (default: 3001)
# PORT=3001
